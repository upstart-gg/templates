{
  "extends": "./tsconfig.json",
  "include": ["vite.config.ts", "react-router.config.ts", ".react-router/types/**/*",
    "app/**/*",
    "app/**/.internal/**/*",
    "app/**/.server/**/*",
    "app/**/.client/**/*",
    "worker-configuration.d.ts",
    "env.d.ts"],
  "exclude": ["app/lib/auth/setup-files/*"],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "resolveJsonModule": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "rootDirs": [".", "./.react-router/types"],
    "types": ["node", "bun", "vite/client"],
    "target": "ES2024",
    "module": "esnext",
    "moduleResolution": "bundler"
  }
}
