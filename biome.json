{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "app/**/*.ts",
      "app/**/*.tsx",
      "app/**/*.json",
      "!app/routes.ts",
      "!app/.internal/**/*"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "off"
      },
      "correctness": {
        "noUnusedVariables": "off",
        "noUnusedFunctionParameters": "off",
        "noUnusedImports": "off"
      },
      "a11y": {
        "noLabelWithoutControl": "off",
        "noSvgWithoutTitle": "off",
        "noNoninteractiveTabindex": "off",
        "noRedundantAlt": "off",
        "useSemanticElements": "off",
        "useButtonType": "off",
        "useValidAnchor": "off",
        "noAutofocus": "off",
        "useKeyWithClickEvents": "off",
        "noStaticElementInteractions": "off",
        "noRedundantRoles": "off"
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "useIterableCallbackReturn": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "json": {
    "linter": {
      "enabled": false
    },
    "parser": {
      "allowComments": true,
      "allowTrailingCommas": true
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  },
  "css": {
    "linter": {
      "enabled": false
    },
    "assist": {
      "enabled": false
    },
    "parser": {
      "tailwindDirectives": true,
      "cssModules": true
    }
  }
}
