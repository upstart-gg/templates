{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "template-default",
  "compatibility_date": "2026-05-14",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": false,
  "main": "./.workers/app.ts",
  "assets": {
    "directory": "./public/",
    "binding": "ASSETS"
  },
  "upload_source_maps": true,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true
    }
  },
  "vars": {}
}
